---
// src/pages/index.astro
// Halaman Landing Page Utama
// Pastikan font dari Google Fonts termuat di bagian head.
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Labsc | Creative Space</title>
    <link href="https://fonts.googleapis.com/css2?family=Patrick+Hand&family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav class="doodle-nav">
      <div class="logo">✨ KaryaUnik</div>
      <ul class="nav-links">
        <li><a href="#about">Tentang</a></li>
        <li><a href="#works">Karya</a></li>
        <li><a href="#contact" class="btn-doodle">Sapa Saya!</a></li>
      </ul>
    </nav>

    <main class="hero-section">
      <div class="hero-content">
        <h1 class="doodle-title">Membangun Sesuatu yang <br> <span class="highlight-blue">Luar Biasa.</span></h1>
        <p class="hero-subtitle">
          Eksplorasi kode, desain, dan inovasi dalam satu wadah yang menyenangkan. Mari ciptakan keajaiban dari baris kode!
        </p>
        <a href="#explore" class="btn-doodle btn-large">Mulai Eksplorasi 🚀</a>
      </div>

      <div class="hero-visuals">
        <div class="doodle-card card-pink" style="--rotation: -3deg; --y-offset: 10px;">
          <h3>Desain Kreatif</h3>
          <p>Bebas berekspresi tanpa batas grid yang membosankan.</p>
        </div>
        <div class="doodle-card card-yellow" style="--rotation: 5deg; --y-offset: -20px;">
          <h3>Kode Bersih</h3>
          <p>Terstruktur dengan baik di balik visual yang ceria.</p>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  /* =========================================
     VARIABEL WARNA PASTEL MILKY & TEMA DOODLE
     ========================================= */
  :root {
    --milky-bg: #fffbf0;       /* Warna latar belakang krem susu */
    --pastel-pink: #ffd1dc;    /* Pink lembut */
    --pastel-blue: #b5e2fa;    /* Biru awan */
    --pastel-yellow: #fffada;  /* Kuning mentega */
    --ink-dark: #2c2c2c;       /* Warna tinta pulpen untuk outline */
    --font-doodle: 'Patrick Hand', cursive;
    --font-body: 'Quicksand', sans-serif;
  }

  /* Reset Dasar */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background-color: var(--milky-bg);
    color: var(--ink-dark);
    font-family: var(--font-body);
    overflow-x: hidden;
    background-image: 
      radial-gradient(var(--pastel-pink) 2px, transparent 2px),
      radial-gradient(var(--pastel-blue) 2px, transparent 2px);
    background-size: 60px 60px;
    background-position: 0 0, 30px 30px; /* Memberikan tekstur polkadot tipis */
  }

  /* =========================================
     NAVIGASI (HEADER)
     ========================================= */
  .doodle-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo {
    font-family: var(--font-doodle);
    font-size: 2.5rem;
    font-weight: bold;
    transform: rotate(-2deg); /* Miring sedikit agar terasa digambar */
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--ink-dark);
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }

  .nav-links a:not(.btn-doodle):hover {
    color: #e58ba2;
    text-decoration: underline wavy 2px; /* Garis bawah bergelombang khas doodle */
  }

  /* =========================================
     STYLE TOMBOL & KOTAK DOODLE (CORE THEME)
     ========================================= */
  /* Trik Border-Radius Asimetris untuk efek gambaran tangan */
  .btn-doodle {
    background-color: var(--pastel-yellow);
    border: 3px solid var(--ink-dark);
    /* Angka-angka ini membuat sudut kotak tidak sempurna */
    border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
    padding: 0.6rem 1.5rem;
    font-family: var(--font-doodle);
    font-size: 1.3rem;
    box-shadow: 4px 4px 0px var(--ink-dark); /* Bayangan solid/harsh shadow */
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-doodle:hover {
    transform: translate(-2px, -2px) rotate(1deg);
    box-shadow: 6px 6px 0px var(--ink-dark);
  }

  .btn-doodle:active {
    transform: translate(2px, 2px);
    box-shadow: 0px 0px 0px var(--ink-dark);
  }

  .btn-large {
    font-size: 1.8rem;
    padding: 1rem 2.5rem;
    background-color: var(--pastel-blue);
    display: inline-block;
    margin-top: 2rem;
  }

  /* =========================================
     LAYOUT BAGIAN HERO (UTAMA)
     ========================================= */
  .hero-section {
    max-width: 1200px;
    margin: 4rem auto;
    padding: 0 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    min-height: 70vh;
  }

  .hero-content {
    flex: 1;
    z-index: 10;
  }

  .doodle-title {
    font-family: var(--font-doodle);
    font-size: 5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .highlight-blue {
    background-color: var(--pastel-blue);
    padding: 0 10px;
    border-radius: 10px 30px 15px 20px;
    display: inline-block;
    transform: rotate(2deg);
    border: 2px dashed var(--ink-dark);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    line-height: 1.6;
    max-width: 450px;
    font-weight: 600;
  }

  /* Kumpulan Visual di Kanan (Scattered Cards) */
  .hero-visuals {
    flex: 1;
    position: relative;
    height: 400px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .doodle-card {
    position: absolute;
    width: 250px;
    padding: 2rem;
    border: 3px solid var(--ink-dark);
    /* Border-radius organik */
    border-radius: 15px 225px 15px 255px/255px 15px 225px 15px;
    box-shadow: 8px 8px 0px var(--ink-dark);
    transform: translateY(var(--y-offset)) rotate(var(--rotation));
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .doodle-card:hover {
    z-index: 100;
    /* Memberikan efek melompat saat di-hover */
    transform: translateY(calc(var(--y-offset) - 15px)) rotate(0deg) scale(1.05);
  }

  .doodle-card h3 {
    font-family: var(--font-doodle);
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .card-pink { background-color: var(--pastel-pink); right: 10%; top: 10%; }
  .card-yellow { background-color: var(--pastel-yellow); left: 10%; bottom: 10%; }

  /* =========================================
     RESPONSIVE DESIGN (MOBILE FRIENDLY)
     ========================================= */
  @media (max-width: 860px) {
    .doodle-nav {
      flex-direction: column;
      gap: 1.5rem;
    }
    
    .hero-section {
      flex-direction: column;
      text-align: center;
      margin: 2rem auto;
    }

    .hero-subtitle {
      margin: 0 auto;
    }

    .doodle-title {
      font-size: 3.5rem;
    }

    .hero-visuals {
      width: 100%;
    }

    .card-pink { position: relative; right: auto; top: auto; margin-bottom: -30px; z-index: 2; }
    .card-yellow { position: relative; left: auto; bottom: auto; margin-left: 50px;}
  }
</style>